# API CONFIG
BASE_URL=http://localhost:3000
CLIENT_URL=http://localhost:3001
# SERVER CONFIG
PORT=3000
HOST=
# COOKIE CONFIG
COOKIE_DOMAIN=localhost
COOKIE_SECRET=secret
# CORS CONFIG
CORS_ORIGIN=http://localhost:3001,http://localhost:4173
CORS_CREDENTIALS=true
# DATABASE CONFIG
DATABASE_URL=mongodb://localhost:27001/?replicaSet=rs0
DATABASE_NAME=papi_starter_dev_db
# EMAIL CONFIG
EMAIL_ENDPOINT=
# FIREBASE CONFIG (for push notifications)
# Option 1: Use service account JSON file (recommended)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Option 2: Use individual environment variables
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# POINTHUB CONFIG
POINTHUB_SECRET=secret